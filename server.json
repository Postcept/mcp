{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.postcept/mcp",
  "description": "Verify agent actions against the system of record and get signed completion receipts.",
  "repository": {
    "url": "https://github.com/Postcept/mcp",
    "source": "github"
  },
  "version": "0.3.2",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@postcept/mcp",
      "version": "0.3.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "POSTCEPT_API_KEY",
          "description": "Postcept API key",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
